 		require.NoError(t, err)
 	})
 }
+
+func TestCreateOrganization(t *testing.T) {
+	t.Parallel()
+
+	client := coderdtest.New(t, nil)
+	user := coderdtest.CreateFirstUser(t, client)
+	ctx := testutil.Context(t, testutil.WaitLong)
+
+	created, err := client.CreateOrganization(ctx, codersdk.CreateOrganizationRequest{
+		Name:        "foundry-qa",
+		DisplayName: "Foundry QA",
+		Description: "Created from the AGPL control plane path.",
+	})
+	require.NoError(t, err)
+	require.Equal(t, "foundry-qa", created.Name)
+	require.Equal(t, "Foundry QA", created.DisplayName)
+	require.False(t, created.IsDefault)
+
+	found, err := client.OrganizationByUserAndName(ctx, codersdk.Me, created.Name)
+	require.NoError(t, err)
+	require.Equal(t, created.ID, found.ID)
+
+	orgs, err := client.OrganizationsByUser(ctx, codersdk.Me)
+	require.NoError(t, err)
+	require.Len(t, orgs, 2)
+	require.Equal(t, user.OrganizationID, orgs[0].ID)
+	require.Equal(t, created.ID, orgs[1].ID)
+}
