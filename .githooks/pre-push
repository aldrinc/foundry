#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

"$repo_root/scripts/check-secrets.sh"

if ! command -v bun >/dev/null 2>&1; then
  echo "bun is required to run Foundry pre-push checks." >&2
  exit 1
fi

if ! command -v cargo >/dev/null 2>&1; then
  echo "cargo is required to run Foundry pre-push checks." >&2
  exit 1
fi

bun run typecheck
bun run lint
bun run check:rust
