{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        "dist/**",
        "src-tauri/target/**",
        "src/**/*.js",
        "src/**/*.jsx",
        "src/**/*.d.ts",
        "src/**/*.d.ts.map",
        "tsconfig.tsbuildinfo"
      ]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "lint": {},
    "test:e2e": {
      "dependsOn": ["build"]
    }
  }
}
