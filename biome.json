{
  "$schema": "https://biomejs.dev/schemas/2.4.6/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!packages/desktop/dist",
      "!packages/desktop/src-tauri/target",
      "!packages/desktop/src-tauri/gen",
      "!packages/desktop/src/bindings.ts",
      "!packages/desktop/src/styles.css",
      "!packages/app/src/**/*.d.ts",
      "!packages/app/src/**/*.d.ts.map",
      "!packages/app/src/**/*.js",
      "!packages/app/src/**/*.jsx",
      "!packages/desktop/src/**/*.d.ts",
      "!packages/desktop/src/**/*.d.ts.map",
      "!packages/desktop/src/**/*.js",
      "!packages/desktop/src/**/*.jsx",
      "!packages/ui/src/**/*.d.ts",
      "!packages/ui/src/**/*.d.ts.map",
      "!packages/ui/src/**/*.js",
      "!packages/ui/src/**/*.jsx",
      "!services/foundry-core/app/**"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space"
  },
  "linter": {
    "enabled": false
  }
}
