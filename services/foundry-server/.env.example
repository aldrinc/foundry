FOUNDRY_ENVIRONMENT=local
FOUNDRY_HOST=127.0.0.1
FOUNDRY_PORT=8090
FOUNDRY_PUBLIC_BASE_URL=http://127.0.0.1:8090
FOUNDRY_API_BASE_URL=http://127.0.0.1:8090
FOUNDRY_SUPPORT_EMAIL=support@example.com
FOUNDRY_DATABASE_PATH=./data/foundry-server.db
FOUNDRY_SELF_HOST_MODE=false

FOUNDRY_AUTH_PROVIDER=oidc
FOUNDRY_OIDC_ISSUER_URL=
FOUNDRY_OIDC_AUDIENCE=
FOUNDRY_OIDC_CLIENT_ID=
FOUNDRY_BOOTSTRAP_ADMIN_EMAIL=
FOUNDRY_BOOTSTRAP_ADMIN_PASSWORD=
FOUNDRY_SESSION_MAX_AGE_DAYS=14
FOUNDRY_CORE_URL=
FOUNDRY_CORE_BOOTSTRAP_SECRET=

FOUNDRY_GITHUB_APP_NAME=Foundry
FOUNDRY_GITHUB_API_URL=https://api.github.com
FOUNDRY_GITHUB_APP_ID=
FOUNDRY_GITHUB_CLIENT_ID=
FOUNDRY_GITHUB_APP_PRIVATE_KEY_PATH=
FOUNDRY_GITHUB_WEBHOOK_SECRET=
FOUNDRY_CODER_URL=
FOUNDRY_CODER_API_TOKEN=
FOUNDRY_WORKSPACE_BOOTSTRAP_SECRET=

FOUNDRY_STRIPE_SECRET_KEY=
FOUNDRY_STRIPE_WEBHOOK_SECRET=

FOUNDRY_WORKSPACE_TOPOLOGY=organization_pooled
FOUNDRY_ORG_WORKSPACE_POOL_SIZE=4
FOUNDRY_ORG_WORKSPACE_MAX_CONCURRENCY=20

FOUNDRY_ORCHESTRATION_ENABLED=true
FOUNDRY_ORCHESTRATION_MOUNT_PATH=/api/v1/meridian
FOUNDRY_ORCHESTRATION_RUN_STORE_PATH=./data/foundry-orchestrator.db
FOUNDRY_ORCHESTRATION_API_TOKEN=
FOUNDRY_ORCHESTRATION_VERIFY_TLS=true
FOUNDRY_ORCHESTRATION_SUPERVISOR_DIR=./data/supervisor
FOUNDRY_ORCHESTRATION_LOCAL_WORK_ROOT=./data/local-work
FOUNDRY_ORCHESTRATION_POLICY_PATH=
