{
  "compilerOptions": {
    "target": "ES2021",
    "module": "ESNext",
    "lib": ["ES2021", "DOM", "DOM.Iterable"],
    "moduleResolution": "bundler",
    "types": ["bun-types"],
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "paths": {
      "@zulip/ui/*": ["../ui/src/*"],
      "@zulip/desktop/*": ["../desktop/src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "../desktop/src/**/*.ts"],
  "references": [
    { "path": "../ui" }
  ]
}
