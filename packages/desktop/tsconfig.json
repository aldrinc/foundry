{
  "compilerOptions": {
    "target": "ES2021",
    "module": "ESNext",
    "lib": ["ES2021", "DOM", "DOM.Iterable"],
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "outDir": ".tsc-out",
    "noEmit": true,
    "paths": {
      "@foundry/ui": ["../ui/src/index.ts"],
      "@foundry/ui/*": ["../ui/src/*"],
      "@foundry/app": ["../app/src/index.ts"],
      "@foundry/app/*": ["../app/src/*"],
      "@foundry/desktop": ["./src/index.tsx"],
      "@foundry/desktop/*": ["./src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["src/**/*.d.ts", "src/**/*.d.ts.map", "src/**/*.js", "src/**/*.jsx"]
}
