{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Foundry",
  "identifier": "org.foundry.desktop",
  "mainBinaryName": "Foundry",
  "version": "0.16.1",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "create": false
      }
    ],
    "withGlobalTauri": true,
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "active": true,
    "createUpdaterArtifacts": true,
    "resources": {
      "resources/notifications/default.wav": "notifications/default.wav"
    },
    "targets": [
      "deb",
      "rpm",
      "dmg",
      "nsis",
      "app"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "foundry",
          "zulip"
        ]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFDN0FCQTRDQ0E5OTJERjcKUldUM0xabktUTHA2SEVYbC9oZE1SWXJyeXZSTnZNdlpxTHBBR09CcWZaSWFHNTE5a2V4S3dqTFUK",
      "endpoints": [
        "https://github.com/aldrinc/foundry/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
