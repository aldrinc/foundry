{
  "name": "foundry",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --cwd packages/desktop dev",
    "build": "bun run --cwd packages/desktop build",
    "test": "bun test",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "test:e2e": "turbo test:e2e"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.8.0"
  }
}
